#!/usr/bin/make -f

export DH_VERBOSE = 1

%:
	dh $@

override_dh_auto_build:
	$(MAKE) VERSION=$(shell dpkg-parsechangelog -S Version | cut -d- -f1)

override_dh_auto_install:
	install -D -m 755 weather $(CURDIR)/debian/weather/usr/bin/weather
	install -D -m 644 weather-completion.bash $(CURDIR)/debian/weather/usr/share/bash-completion/completions/weather

override_dh_auto_clean:
	$(MAKE) clean || true
